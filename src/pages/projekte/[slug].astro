---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projekte = await getCollection('projekte');
  return projekte.map((projekt) => ({
    params: { slug: projekt.id },
    props: { projekt },
  }));
}

const { projekt } = Astro.props;
const { Content } = await render(projekt);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title={projekt.data.title}>
  <div class="content-page">
    <div class="container">
      <h1>{projekt.data.title}</h1>
      <div class="article-body">
        <Content />
      </div>
      <a href={`${base}/projekte`} class="back-link">← Zurück zur Übersicht</a>
    </div>
  </div>
</BaseLayout>
